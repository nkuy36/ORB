// Abbreviate dollar volume (input is in millions): shows "B" once the value passes 999M, otherwise "M"
f_fmtDollarVol(_valM) =>
    _valM >= 1000 ? str.tostring(_valM / 1000, "#.##") + "B" : str.tostring(_valM, "#") + "M"

// Abbreviate a raw share-volume count with K / M / B suffixes
f_fmtVol(_v) =>
    _v >= 1e9 ? str.tostring(_v / 1e9, "#.##") + "B" : _v >= 1e6 ? str.tostring(_v / 1e6, "#.##") + "M" : _v >= 1e3 ? str.tostring(_v / 1e3, "#.#") + "K" : str.tostring(_v, "#")

f_cell(_t, _orient, _r, _l, _v, _vc, _bg, _theme, _size) =>
    c1 = _orient == "Vertical" ? 0 : _r
    r1 = _orient == "Vertical" ? _r : 0
    c2 = _orient == "Vertical" ? 1 : _r
    r2 = _orient == "Vertical" ? _r : 1
    f_tx = _theme == "Dark" ? color.white : color.black
    table.cell(_t, c1, r1, _l, text_color=f_tx, text_size=_size)
    table.cell(_t, c2, r2, _v, text_color=_vc, bgcolor=_bg, text_size=_size)

//---------------------------------------------------------------------------------------------------------------------}
// 2. TIMEFRAME-AGNOSTIC DATA
//---------------------------------------------------------------------------------------------------------------------{
// --- PART A: CORE SOS MARKET CONTEXT (CHOP & TREND) ---
// 1. Chop Function (From CORE SOS)
f_chopIndex(_p) =>
    _atrSum = math.sum(ta.atr(1), _p)
    _hiMax  = ta.highest(high, _p)
    _loMin  = ta.lowest(low, _p)
    _denom  = _hiMax - _loMin
    _denom := _denom == 0 ? 1 : _denom
    100 * math.log10(_atrSum / _denom) / math.log10(_p)

// 2. Fetch Market Data (SPY Price, SMA 200, Chop Index)
// Note: We use 14 for Chop Period as per CORE SOS defaults
[idxClose, idxSMA200, idxChopVal] = request.security(mktIndex, "D", [close, ta.sma(close, 200), f_chopIndex(14)])

// 3. Determine Context State (The "Road Conditions")
string mktState = "N/A"
color mktColor  = color.gray

// Thresholds from CORE SOS
float chopChaos = 61.8
float chopTrans = 50.0
float chopTrend = 38.2

if idxClose < idxSMA200
    mktState := "IDX: BEAR (CASH)"
    mktColor := color.red
else
    if idxChopVal > chopChaos
        mktState := "IDX: CHAOS (TRAPS)"
        mktColor := color.orange
    else if idxChopVal > chopTrans
        mktState := "IDX: TRANSITION"
        mktColor := color.yellow
    else
        mktState := "IDX: SUPER TREND"
        mktColor := color.green

// --- PART B: LUK LEADER BREADTH (The "Engine Power") ---
// Using your existing Leader inputs (sym1 - sym10)
f_isLeading(_s, _e9, _e21, _e50) =>
    [c, e9, e21, e50] = request.security(_s, "D", [close, ta.ema(close, _e9), ta.ema(close, _e21), ta.ema(close, _e50)], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_on)
    c > e9 and e9 > e21 and e21 > e50 ? 1 : 0

int leaderCount = 0
leaderCount += f_isLeading(sym1,  ema9Len, ema21Len, ema50Len)
leaderCount += f_isLeading(sym2,  ema9Len, ema21Len, ema50Len)
leaderCount += f_isLeading(sym3,  ema9Len, ema21Len, ema50Len)
leaderCount += f_isLeading(sym4,  ema9Len, ema21Len, ema50Len)
leaderCount += f_isLeading(sym5,  ema9Len, ema21Len, ema50Len)
leaderCount += f_isLeading(sym6,  ema9Len, ema21Len, ema50Len)
leaderCount += f_isLeading(sym7,  ema9Len, ema21Len, ema50Len)
leaderCount += f_isLeading(sym8,  ema9Len, ema21Len, ema50Len)
leaderCount += f_isLeading(sym9,  ema9Len, ema21Len, ema50Len)
leaderCount += f_isLeading(sym10, ema9Len, ema21Len, ema50Len)
leaderCount += f_isLeading(sym11, ema9Len, ema21Len, ema50Len)
leaderCount += f_isLeading(sym12, ema9Len, ema21Len, ema50Len)
leaderCount += f_isLeading(sym13, ema9Len, ema21Len, ema50Len)
leaderCount += f_isLeading(sym14, ema9Len, ema21Len, ema50Len)
leaderCount += f_isLeading(sym15, ema9Len, ema21Len, ema50Len)
leaderCount += f_isLeading(sym16, ema9Len, ema21Len, ema50Len)
leaderCount += f_isLeading(sym17, ema9Len, ema21Len, ema50Len)
leaderCount += f_isLeading(sym18, ema9Len, ema21Len, ema50Len)

// --- PART C: ACTION PLAN (Hybrid: Chop Context + Sector Breadth) ---
string actionText = "WAIT"
color actionColor = color.gray

// 1. Safety First: Check SOS Market Context (Chop/Trend)
if mktState == "IDX: BEAR (CASH)"
    actionText  := "CASH / SHORTS"
    actionColor := color.red
else if mktState == "IDX: CHAOS (TRAPS)"
    actionText  := "TRAPS ONLY / SMALL"
    actionColor := color.orange
else
    // 2. Engine Power: If Context is Safe, check Sector Breadth
    // Adjusted thresholds for 18 ETFs:
    // Full Size: > 12 (approx 66%) -> Strong Bull
    // Selective: > 6  (approx 33%) -> Mixed Market
    if leaderCount >= 12
        actionText  := "FULL SIZE ENTRY"
        actionColor := color.green
    else if leaderCount >= 6
        actionText  := "SELECTIVE / HALF"
        actionColor := color.yellow
    else
        actionText  := "CAUTION / WEAK"
        actionColor := color.orange

// --- Chart Data & Volume Logic (Preserved from V4.4) ---
[dClose, dHigh, dLow, dOpen, dPrevHigh, dPrevLow, dPrevClose, dE9, dE21, dE50, dADR, dAvgVol, dDollarVolRaw, dVolToday] = request.security(syminfo.tickerid, "D", [close, high, low, open, high[1], low[1], close[1], ta.ema(close, ema9Len), ta.ema(close, ema21Len), ta.ema(close, ema50Len), ta.sma(high - low, 20), ta.sma(volume, 20), ta.sma(close * volume, 20), volume], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_on)

// --- VOLUME (RVOL uses DAILY volume / 20-day avg so it reads IDENTICALLY on every chart timeframe) ---
// Note: on the live day this is the running daily total vs the 20-day average (not intraday-pace-adjusted),
// which is the trade-off for making the value consistent across timeframes.
float dollarVol = dDollarVolRaw / 1000000
float dAvgVol_Safe = math.max(1, dAvgVol)
float rvol = dVolToday / dAvgVol_Safe

// --- PRE-MARKET LOW & VOLUME (extended hours, timeframe-agnostic) ---
// Uses an EXTENDED-session ticker so the 04:00-09:30 pre-market bars are included, and a
// running 1-minute calculation so the values are identical on ANY chart timeframe (intraday OR daily).
// Requires the symbol/plan to have pre-market (extended hours) data available.
f_premarket() =>
    var float pmL = na
    var float pmV = na
    bool inPM   = not na(time(timeframe.period, "0400-0930", tz))
    bool pmStart = inPM and not inPM[1]
    if pmStart
        pmL := low
        pmV := volume
    else if inPM
        pmL := math.min(pmL, low)
        pmV := pmV + volume
    [pmL, pmV]

extID = ticker.new(syminfo.prefix, syminfo.ticker, session.extended)
[pmLow, pmVol] = request.security(extID, "1", f_premarket(), gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)

// Status Variables
bool isLeading = dClose > dE9 and dE9 > dE21 and dE21 > dE50
bool isInsideDay = dPrevHigh > dHigh and dPrevLow < dLow
float adrPct = (dADR / dClose) * 100

//---------------------------------------------------------------------------------------------------------------------}
// 3. CORE ORB ENGINE & PARABOLIC RISK LOGIC (RESTORED)
//---------------------------------------------------------------------------------------------------------------------{
var float orh = na, var float orl = na, var float lod = na
var float prev_orm = na
var float autoEntry = na, var float autoSL = na
session_time = crMode == "Presets" ? crSeshPreset : crSeshManual
or_sesh = not na(time(timeframe.period, session_time, tz))
or_start = or_sesh and not or_sesh[1]

if or_start
    if not na(orh) and not na(orl)
        prev_orm := math.avg(orh, orl)
    orh := high, orl := low, lod := low, autoEntry := na, autoSL := na

if or_sesh
    orh := math.max(orh, high), orl := math.min(orl, low), lod := math.min(lod, low)

bool activeTrade = not na(autoEntry)

if not activeTrade and high > orh
    autoEntry := orh
    // --- RESTORED PARABOLIC LOGIC (Triggered AT ENTRY) ---
    // Wide stop is LOD or ORL based on user choice
    float wideStop = wideStopMode == "ORL" ? orl : lod
    float distToWideStop = ((autoEntry - wideStop) / autoEntry) * 100
    if distToWideStop > maxRiskPct
        autoSL := ta.lowest(low, stopLookback) // Snap to lowest low of N candles
    else
        autoSL := wideStop

// Dynamic Exit Strategy (User-Selected Trail Anchor)
float activeTrailingStop = na
if trailAnchorChoice == "21 EMA"
    activeTrailingStop := dE21
else
    activeTrailingStop := dE9

//---------------------------------------------------------------------------------------------------------------------}
// 4. MASTER LUK INSTITUTIONAL RISK & POSITION SIZING ENGINE
//---------------------------------------------------------------------------------------------------------------------{
// 1. Fetch Multi-Timeframe Data
[monActive, monClose, monEntry, monSL, monLow5m, monE9, monORH, monORL, monLOD] = request.security(syminfo.tickerid, monitorTF, [activeTrade, close, autoEntry, autoSL, low, ta.ema(close, 9), orh, orl, lod], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_on)
[checkClose, checkE9] = request.security(syminfo.tickerid, trendCheckTF, [close, ta.ema(close, 9)], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_on)

// 2. UNIFIED VARIABLES (THE PERSISTENCE BRIDGE)
bool isHTF = timeframe.isdaily or timeframe.isweekly
bool isPlannerMode = manEntryInput > 0

// --- THESE ARE THE THREE KEY BRIDGE LINES YOU ASKED FOR ---
// TF-agnostic: use the 5-min-monitored ORB levels on EVERY timeframe so entry/stop (and therefore Risk %,
// LUK Alloc, Share Count and the Risk/Sniper grade) read the same on the Daily as on intraday.
// Entry = ORH (breakout level), or the locked autoEntry once a trade triggers. Stop = LOD, or the locked autoSL.
float reportEntry = isPlannerMode ? manEntryInput : (monActive ? monEntry : monORH)
float rawSL       = isPlannerMode ? (manStopInput > 0 ? manStopInput : monLOD) : (monActive ? monSL : monLOD)
float reportClose = isHTF ? monClose : close

// 3. PLANNER OVERRIDE LOGIC (Ensures Manual Inputs work)
if isPlannerMode
    float planWideStop = wideStopMode == "ORL" ? monORL : monLOD
    float planDist = ((manEntryInput - planWideStop) / manEntryInput) * 100
    float autoPlanSL = planDist > maxRiskPct ? (manEntryInput * (1 - maxRiskPct/100)) : planWideStop
    rawSL := (manStopInput > 0) ? manStopInput : autoPlanSL

// 4. LUK DYNAMIC STOP SNAP (VOLATILITY ADJUSTMENT)
float currentADRPct = (dADR / dClose) * 100
float halfADR       = currentADRPct * 0.5
float maxLukStopPct = maxRiskPct

float reportSL = rawSL

// LOGIC FIX: Only force the "Snap to 5m Low" if we are PLANNING.
// If the trade is ACTIVE, we trust 'rawSL' because it was already locked at the entry moment.
if isPlannerMode
    // Check if the wide stop is too wide
    if ((reportEntry - rawSL) / reportEntry * 100) > maxLukStopPct
        // In Planner Mode, use lowest low of N candles as proxy for "Tight Stop"
        reportSL := monLow5m

// 5. MATH MODULE (Using the finalized, snapped reportSL)
float lukRiskAmt   = math.abs(reportEntry - reportSL)
float tradeRiskPct = (reportEntry > 0) ? (lukRiskAmt / reportEntry) * 100 : 0.0
float currentR     = (lukRiskAmt > 0.0001) ? (reportClose - reportEntry) / lukRiskAmt : 0.0

// 6. LUK CONCENTRATION & ALLOCATION
// A. Determine Hard Cap based on Asset Class
float maxAllocPct = 30.0 // Default for Standard
if lukTier == "Speculative (Small Cap)"
    maxAllocPct := 20.0 // Cap at 20% for gap protection (Small Caps)
else if lukTier == "Slow Mover (ETF/Metal)"
    maxAllocPct := 40.0 // Allow >35% for low volatility instruments

// B. Determine Risk Intent (Drawdown Rule)
// If Equity Highs = 0.5% (or whatever is set). If Drawdown = Half of that.
float currentRiskIntent = (marketState == "Equity Highs") ? riskPerTrade : (riskPerTrade * 0.5)

// C. The "Core Formula" (Risk-Based Sizing)
// Formula: ($Account * Risk%) / StopLoss%
float sizingByRisk = (tradeRiskPct > 0) ? (accountSize * (currentRiskIntent / 100)) / (tradeRiskPct / 100) : 0

// D. The Hard Cap Check
float sizingByCap  = accountSize * (maxAllocPct / 100)

// E. Final Position Size (Whichever is smaller)
float finalPositionSize = math.min(sizingByRisk, sizingByCap)

// F. Output Calculations
float shareSize       = (reportEntry > 0) ? math.floor(finalPositionSize / reportEntry) : 0
float currentAllocPct = (finalPositionSize / accountSize) * 100

//---------------------------------------------------------------------------------------------------------------------}
// 7. INSTITUTIONAL VALIDITY & TREND SYNC (FINALIZED "GO" LOGIC)
//---------------------------------------------------------------------------------------------------------------------{
// 1. Speed Check (ADR) — threshold from group 9
bool valid_Speed = currentADRPct >= sqAdrMin

// 2. Risk Check (Tightness) — threshold from group 9
bool valid_Risk  = tradeRiskPct <= sqRiskMax

// 3. Context Check (Market Breadth + SOS Safety)
// Luk Rule: "Wind at your back". Market must not be in Chaos/Bear.
bool valid_Context = leaderCount >= 12 and (mktState == "IDX: SUPER TREND" or mktState == "IDX: TRANSITION")

// 4. Structure Check (stacked uptrend: Price > 9 > 21 > 50)
bool valid_Structure = isLeading

// 5. ORH Reclaim — computed on a 5-min intraday feed via request.security, so the status is available on
// EVERY chart timeframe (including the Daily). This lets you scan the watchlist on the Daily and still see
// which names have cleared today's Opening Range High. Reclaim = a 5-min bar CLOSES above the ORH after the
// opening-range window ends, and it stays "reclaimed" for the rest of the day.
// "If the stock fails to clear the ORH, the setup is lower quality." (Luk protocol)
f_orhReclaim() =>
    var float _orh = na
    var bool  _rcl = false
    bool _inOR    = not na(time(timeframe.period, session_time, tz))
    bool _orStart = _inOR and not _inOR[1]
    if _orStart
        _orh := high
        _rcl := false
    else if _inOR
        _orh := math.max(_orh, high)
    if not _inOR and not na(_orh) and close > _orh
        _rcl := true
    [_orh, _rcl]

[orhIntraday, orhReclaimedTF] = request.security(syminfo.tickerid, "5", f_orhReclaim(), gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
bool orhAppl   = not na(orhIntraday)
bool valid_ORH = orhReclaimedTF

// 6. Dollar Volume (liquidity) & 7. RVOL (volume confirmation) — thresholds reused from group 4
bool valid_DolVol = dollarVol >= minDollarVol
bool valid_RVOL   = rvol >= rvolThreshold

// 8. EMA Coil (9-21-50 converging tightly = volatility contraction), measured on the daily EMAs
float emaSpreadPct = (dClose > 0) ? (math.max(dE9, dE21, dE50) - math.min(dE9, dE21, dE50)) / dClose * 100 : na
bool valid_Coil = not na(emaSpreadPct) and emaSpreadPct <= sqCoilMax

// 9. Sniper tight stop
bool valid_Sniper = tradeRiskPct <= sqSniperMax

// 10. Anchored VWAP confluence — computed on DAILY bars via request.security so the AVWAP reads IDENTICALLY
// on every chart timeframe (and matches how Luk anchors AVWAP on the daily). Manual = accumulate from the
// anchor date/time; Auto = re-anchor at the most recent confirmed daily pivot low.
f_avwap() =>
    var float _pv = na
    var float _v  = na
    var bool  _started = false
    bool _after = time >= avwapAnchorTime
    if _after
        if not _started
            _pv := hlc3 * volume
            _v  := volume
            _started := true
        else
            _pv := _pv + hlc3 * volume
            _v  := _v + volume
    float _manual = (not na(_v) and _v > 0) ? _pv / _v : na
    bool  _autoAnchor = not na(ta.pivotlow(low, avwapAutoLb, avwapAutoLb))
    float _auto = ta.vwap(hlc3, _autoAnchor)
    avwapMode == "Manual" ? _manual : _auto

float avwapVal = request.security(syminfo.tickerid, "D", f_avwap(), gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
float avwapDistPct = (not na(avwapVal) and avwapVal > 0) ? (close - avwapVal) / avwapVal * 100 : na
bool  avwapAppl = not na(avwapVal)
bool  valid_AVWAP = avwapAppl and close >= avwapVal

// 11. Relative Strength (breadth health): is the Leader (IWM) outperforming the Benchmark (QQQ) over the lookback?
// Luk: IWM leading QQQ = healthy breadth, low deep-correction odds.
[rsLdNow, rsLdPast] = request.security(rsLeader, "D", [close, close[rsLen]], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_on)
[rsBnNow, rsBnPast] = request.security(rsBench,  "D", [close, close[rsLen]], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_on)
float rsLeaderRoc = (not na(rsLdPast) and rsLdPast != 0) ? (rsLdNow - rsLdPast) / rsLdPast * 100 : na
float rsBenchRoc  = (not na(rsBnPast) and rsBnPast != 0) ? (rsBnNow - rsBnPast) / rsBnPast * 100 : na
bool  rsAppl   = not na(rsLeaderRoc) and not na(rsBenchRoc)
bool  valid_RS = rsAppl and rsLeaderRoc >= rsBenchRoc

// --- GRADED SETUP QUALITY (score of ENABLED, applicable criteria that pass) ---
// ORH and AVWAP only count toward the total when they are applicable (e.g. ORH is N/A on the Daily),
// so an un-evaluable criterion never unfairly drags the grade down.
int sqTotal = (sqSpeed?1:0) + (sqRisk?1:0) + (sqContext?1:0) + (sqStructure?1:0) + (sqORH and orhAppl?1:0) + (sqDolVol?1:0) + (sqRVOL?1:0) + (sqCoil?1:0) + (sqSniper?1:0) + (sqAVWAP and avwapAppl?1:0) + (sqRS and rsAppl?1:0)
int sqPass  = (sqSpeed and valid_Speed?1:0) + (sqRisk and valid_Risk?1:0) + (sqContext and valid_Context?1:0) + (sqStructure and valid_Structure?1:0) + (sqORH and orhAppl and valid_ORH?1:0) + (sqDolVol and valid_DolVol?1:0) + (sqRVOL and valid_RVOL?1:0) + (sqCoil and valid_Coil?1:0) + (sqSniper and valid_Sniper?1:0) + (sqAVWAP and avwapAppl and valid_AVWAP?1:0) + (sqRS and rsAppl and valid_RS?1:0)
float sqRatio = sqTotal > 0 ? (sqPass * 1.0) / sqTotal : 0.0
string sqGrade = sqTotal == 0 ? "OFF" : sqRatio >= 1.0 ? "A+" : sqRatio >= 0.75 ? "A" : sqRatio >= 0.55 ? "B" : sqRatio >= 0.35 ? "C" : "WEAK"
color sqColor = sqGrade == "A+" ? color.new(color.green, 0) : sqGrade == "A" ? color.green : sqGrade == "B" ? color.orange : sqGrade == "C" ? color.new(color.orange, 35) : sqGrade == "OFF" ? color.gray : color.red

// --- HIGH-QUALITY "GO" SIGNAL (grade A or better) — feeds the LUK entry signal/alert ---
bool luk_Setup = sqTotal > 0 and sqRatio >= 0.75

bool trendSync   = (monClose > monE9) and (checkClose > checkE9)
color dashHeaderCol = trendSync ? color.new(color.aqua, 20) : (dashTheme == "Dark" ? color.new(color.black, 20) : color.new(color.white, 20))
// 8. STATUS LOGIC (Visual Feedback)
bool pullTo9 = isLeading and low <= dE9 and close > dE9
bool monPullTo9 = not na(monE9) and low <= monE9 and close > monE9
string combinedStatus = ""
color statusCol = color.gray

if isPlannerMode
    combinedStatus := "PLANNER: " + str.tostring(manEntryInput, format.mintick)
    statusCol := color.blue
else
    if (activeTrade or (isHTF and not na(monEntry)))
        combinedStatus := "ACTIVE @ " + str.tostring(reportEntry, format.mintick)
        statusCol := color.green
    else
        if isHTF
            combinedStatus := monitorTF + "m: " + str.tostring(monClose, format.mintick)
            statusCol := monPullTo9 ? color.yellow : color.gray
        else
            combinedStatus := pullTo9 ? "9 EMA PULL" : "WAIT"
            statusCol := pullTo9 ? color.yellow : color.gray

// Anchors for Dashboard Styling
string lukStopType = (reportSL != rawSL) ? "5m SNAP" : (wideStopMode == "ORL" ? "ORL" : "LOD")
string trailAnchor = trailAnchorChoice
color trailCol     = trailAnchorChoice == "21 EMA" ? color.yellow : color.blue
color rColor       = currentR >= 3.0 ? color.green : currentR < 1.0 ? color.red : color.orange

//---------------------------------------------------------------------------------------------------------------------}
// 5. PLOTTING & DRAWING
//---------------------------------------------------------------------------------------------------------------------{
plot(ema9On  ? dE9 : na, "MA 2 (9 EMA)", color=ma2Col, linewidth=2)
plot(ema21On ? dE21 : na, "MA 3 (21 EMA)", color=ma3Col, linewidth=2)
plot(ema50On ? dE50 : na, "MA 4 (50 EMA)", color=ma4Col, linewidth=2)

var box orbBox = na
bool showVisuals = timeframe.isintraday and timeframe.multiplier <= 60

if or_start and showVisuals
    orbBox := box.new(bar_index, orh, bar_index, orl, bgcolor=orFillColor, border_width=1, border_color=orColor)

if or_sesh and not na(orbBox)
    box.set_right(orbBox, bar_index)
    box.set_top(orbBox, orh)
    box.set_bottom(orbBox, orl)
    curr_orm = math.avg(orh, orl)
    if not na(prev_orm)
        box.set_bgcolor(orbBox, curr_orm >= prev_orm ? bullFill : bearFill)

// Extend box past session end if Extended mode is selected
if not or_sesh and not na(orbBox) and orBoxMode == "Extended"
    box.set_right(orbBox, bar_index)
    box.set_top(orbBox, orh)
    box.set_bottom(orbBox, orl)
    // Cap extension so it doesn't bleed into next day
    int barsSinceStart = bar_index - box.get_left(orbBox)
    if barsSinceStart > orBoxExtBars
        box.set_right(orbBox, box.get_left(orbBox) + orBoxExtBars)

// ORH/ORL Labels & Lines
var line orhL = na, var line orlL = na
var label orhLab = na, var label orlLab = na
if or_start and showVisuals
    line.delete(orhL), line.delete(orlL)
    label.delete(orhLab), label.delete(orlLab)
    orhL := line.new(bar_index, orh, bar_index + 10, orh, color=orColor, width=2)
    orlL := line.new(bar_index, orl, bar_index + 10, orl, color=orColor, width=2)
    orhLab := label.new(bar_index, orh, "ORH: " + str.tostring(orh, format.mintick), style=label.style_label_left, color=color.rgb(0,0,0,100), textcolor=orColor, size=get_size(labelSizeInput))
    orlLab := label.new(bar_index, orl, "ORL: " + str.tostring(orl, format.mintick), style=label.style_label_left, color=color.rgb(0,0,0,100), textcolor=orColor, size=get_size(labelSizeInput))

if not na(orhL)
    line.set_x2(orhL, bar_index), line.set_y1(orhL, orh), line.set_y2(orhL, orh)
    line.set_x2(orlL, bar_index), line.set_y1(orlL, orl), line.set_y2(orlL, orl)
    label.set_x(orhLab, bar_index), label.set_y(orhLab, orh)
    label.set_text(orhLab, "ORH: " + str.tostring(orh, format.mintick))
    label.set_x(orlLab, bar_index), label.set_y(orlLab, orl)
    label.set_text(orlLab, "ORL: " + str.tostring(orl, format.mintick))

// PDH and Signals
plot(showPDH ? dPrevHigh : na, "PDH Line", color=pdhColor, style=plot.style_circles)

var label pdhLab = na
if barstate.islast and showVisuals
    label.delete(pdhLab)
    if showPDH and not na(dPrevHigh)
        pdhLab := label.new(bar_index, dPrevHigh, "PDH: " + str.tostring(dPrevHigh, format.mintick), style=label.style_label_left, color=color.rgb(0,0,0,100), textcolor=color.new(pdhColor, 0), size=get_size(labelSizeInput))

// PML (Pre-Market Low) - same visual treatment as PDH
plot(showPML ? pmLow : na, "PML Line", color=pmlColor, style=plot.style_circles)

var label pmlLab = na
if barstate.islast and showVisuals
    label.delete(pmlLab)
    if showPML and not na(pmLow)
        pmlLab := label.new(bar_index, pmLow, "PML: " + str.tostring(pmLow, format.mintick), style=label.style_label_left, color=color.rgb(0,0,0,100), textcolor=color.new(pmlColor, 0), size=get_size(labelSizeInput))

// Anchored VWAP (confluence support) - anchor mode/date set in group 9
plot(sqShowAVWAP and sqAVWAP ? avwapVal : na, "Anchored VWAP", color=avwapColor, linewidth=2)

// Triangle Visual
bool lukSignalSync = (isHTF ? monActive : activeTrade) and not (isHTF ? monActive[1] : activeTrade[1]) and trendSync and luk_Setup and leaderCount >= 7

plotshape(lukSignalSync, title="LUK Signal", style=shape.triangleup, location=location.belowbar, color=color.new(color.green, 0), size=size.small, text="LUK BUY", textcolor=color.green)

// --- TARGET PROFIT MODULE ---
var targetLine[] tpLines = array.new<targetLine>()
if barstate.islast
    if array.size(tpLines) > 0
        for i = 0 to array.size(tpLines) - 1
            tl = array.get(tpLines, i)
            line.delete(tl.ln)
            label.delete(tl.lb)
        array.clear(tpLines)

f_handleTP(_on, _rMult, _curR, _ePrice, _rAmt, _dispType, _showLab, _lSize, _targetArray) =>
    if _on and not na(_ePrice) and not na(_rAmt)
        _val = _ePrice + (_rAmt * _rMult)
        _pct = ((_val - _ePrice) / _ePrice) * 100
        _shouldShow = _dispType == "Extended" or (_curR >= (_rMult - 3.5) and _curR < _rMult + 0.5)
        if _shouldShow and barstate.islast
            ln = line.new(bar_index - 10, _val, bar_index, _val, color=color.new(color.green, 50), style=line.style_dashed)
            label lb = na
            if _showLab
                _txt = str.tostring(_rMult, "#.#") + "R (" + str.tostring(_pct, "#.#") + "%)"
                lb := label.new(bar_index, _val, _txt, style=label.style_label_left, color=color.rgb(0,0,0,100), textcolor=color.green, size=get_size(_lSize))
            array.push(_targetArray, targetLine.new(ln, lb))

if (activeTrade or (isHTF and not na(monEntry)) or isPlannerMode)
    // Use 'reportClose' here to keep the R-Multiple frozen correctly after market hours
    float finalCurrentR = (reportClose - reportEntry) / math.max(0.00001, lukRiskAmt)

    f_handleTP(tp1_on, tp1_v, finalCurrentR, reportEntry, lukRiskAmt, tDispType, showTPLabels, labelSizeInput, tpLines)
    f_handleTP(tp2_on, tp2_v, finalCurrentR, reportEntry, lukRiskAmt, tDispType, showTPLabels, labelSizeInput, tpLines)
    f_handleTP(tp3_on, tp3_v, finalCurrentR, reportEntry, lukRiskAmt, tDispType, showTPLabels, labelSizeInput, tpLines)
    f_handleTP(tp5_on, tp5_v, finalCurrentR, reportEntry, lukRiskAmt, tDispType, showTPLabels, labelSizeInput, tpLines)
    f_handleTP(tp8_on, tp8_v, finalCurrentR, reportEntry, lukRiskAmt, tDispType, showTPLabels, labelSizeInput, tpLines)

//---------------------------------------------------------------------------------------------------------------------}
// 6. DASHBOARD
//---------------------------------------------------------------------------------------------------------------------{
if showDash and barstate.islast
    pos = switch dashPos
        "Top Left"      => position.top_left
        "Top Right"     => position.top_right
        "Bottom Left"   => position.bottom_left
        "Bottom Right"  => position.bottom_right
        "Top Center"    => position.top_center
        "Bottom Center" => position.bottom_center
        "Middle Left"   => position.middle_left
        "Middle Right"  => position.middle_right
        => position.top_right

    // Count visible rows for dynamic table sizing
    int visibleRows = (showRow0 ? 1:0) + (showRow1 ? 1:0) + (showRow2 ? 1:0) + (showRow3 ? 1:0) + (showRow4 ? 1:0) + (showRow5 ? 1:0) + (showRow6 ? 1:0) + (showRow7 ? 1:0) + (showRow8 ? 1:0) + (showRow9 ? 1:0) + (showRow10 ? 1:0) + (showRow11 ? 1:0) + (showRow12 ? 1:0) + (showRow13 ? 1:0) + (showRow14 ? 1:0) + (showRow15 ? 1:0) + (showRow16 ? 1:0) + (showRow17 ? 1:0) + (showRow18 ? 1:0) + (showRow19 ? 1:0) + (showRow20 ? 1:0) + (showRow21 ? 1:0) + (showRow22 ? 1:0)

    dashTable = table.new(pos, dashOrient=="Vertical"?2:visibleRows, dashOrient=="Vertical"?visibleRows:2, bgcolor=dashHeaderCol, border_width=1)
    dSize = get_size(txtSizeInput)

    int r = 0
    if showRow0
        f_cell(dashTable, dashOrient, r, "Market Context", mktState, color.white, mktColor, dashTheme, dSize)
        r += 1
    if showRow1
        f_cell(dashTable, dashOrient, r, "Action Plan", actionText, color.white, actionColor, dashTheme, dSize)
        r += 1
    if showRow2
        f_cell(dashTable, dashOrient, r, "Trend State", isLeading ? "LEADING" : "MEDIOCRE", color.white, isLeading ? color.green : color.red, dashTheme, dSize)
        r += 1
    if showRow3
        f_cell(dashTable, dashOrient, r, "Sector Breadth", str.tostring(leaderCount) + "/18", color.white, leaderCount >= 12 ? color.green : leaderCount >= 6 ? color.orange : color.red, dashTheme, dSize)
        r += 1
    if showRow4
        f_cell(dashTable, dashOrient, r, "Entry Status", combinedStatus, color.black, statusCol, dashTheme, dSize)
        r += 1
    if showRow5
        f_cell(dashTable, dashOrient, r, "Inside Day", isInsideDay ? "YES" : "NO", isInsideDay ? color.black : color.white, isInsideDay ? color.yellow : color.gray, dashTheme, dSize)
        r += 1
    if showRow6
        f_cell(dashTable, dashOrient, r, "Setup Quality", sqGrade + " (" + str.tostring(sqPass) + "/" + str.tostring(sqTotal) + ")", color.white, sqColor, dashTheme, dSize)
        r += 1
    if showRow7
        f_cell(dashTable, dashOrient, r, "ADR % (Speed)", str.tostring(adrPct, "#.#") + "%", color.white, valid_Speed ? color.green : color.gray, dashTheme, dSize)
        r += 1
    if showRow8
        f_cell(dashTable, dashOrient, r, "Vol Stop", str.tostring(reportSL, format.mintick), color.white, color.gray, dashTheme, dSize)
        r += 1
    if showRow9
        f_cell(dashTable, dashOrient, r, "Dollar Vol", f_fmtDollarVol(dollarVol), color.white, dollarVol > minDollarVol ? color.green : color.orange, dashTheme, dSize)
        r += 1
    if showRow10
        color riskWarningCol = tradeRiskPct > maxRiskPct ? color.new(color.red, 20) : color.gray
        f_cell(dashTable, dashOrient, r, "Trade Risk %", str.tostring(tradeRiskPct, "#.##") + "%", color.white, riskWarningCol, dashTheme, dSize)
        r += 1
    if showRow11
        color rMultipleBg = currentR >= 3.0 ? color.new(color.fuchsia, 30) : rColor
        f_cell(dashTable, dashOrient, r, "Est. R-Multiple", str.tostring(currentR, "#.##") + " R", color.white, rMultipleBg, dashTheme, dSize)
        r += 1
    if showRow12
        f_cell(dashTable, dashOrient, r, "Risk Validity", valid_Risk ? "VALID" : "HIGH RISK", color.white, valid_Risk ? color.green : color.red, dashTheme, dSize)
        r += 1
    if showRow13
        string allocText = str.tostring(finalPositionSize / 1000, "#.#") + "K (" + str.tostring(currentAllocPct, "#") + "%)"
        f_cell(dashTable, dashOrient, r, "LUK ALLOC %", allocText, color.white, color.blue, dashTheme, dSize)
        r += 1
    if showRow14
        f_cell(dashTable, dashOrient, r, "Share Count", str.tostring(shareSize, "#"), color.white, color.blue, dashTheme, dSize)
        r += 1
    if showRow15
        f_cell(dashTable, dashOrient, r, "Stop: " + lukStopType, str.tostring(reportSL, format.mintick), color.white, color.gray, dashTheme, dSize)
        r += 1
    if showRow16
        float trailPrice = trailAnchorChoice == "21 EMA" ? dE21 : dE9
        f_cell(dashTable, dashOrient, r, "Trail " + trailAnchor, str.tostring(trailPrice, format.mintick), color.white, trailCol, dashTheme, dSize)
        r += 1
    if showRow17
        f_cell(dashTable, dashOrient, r, "PM Volume", na(pmVol) ? "N/A" : f_fmtVol(pmVol), color.white, color.gray, dashTheme, dSize)
        r += 1
    if showRow18
        f_cell(dashTable, dashOrient, r, "RVOL", str.tostring(rvol, "#.##") + "x", color.white, valid_RVOL ? color.green : color.gray, dashTheme, dSize)
        r += 1
    if showRow19
        f_cell(dashTable, dashOrient, r, "EMA Spread", na(emaSpreadPct) ? "N/A" : str.tostring(emaSpreadPct, "#.#") + "%", color.white, valid_Coil ? color.green : color.gray, dashTheme, dSize)
        r += 1
    if showRow20
        f_cell(dashTable, dashOrient, r, "ORH Reclaim", not orhAppl ? "N/A" : valid_ORH ? "YES" : "NO", color.white, not orhAppl ? color.gray : valid_ORH ? color.green : color.red, dashTheme, dSize)
        r += 1
    if showRow21
        f_cell(dashTable, dashOrient, r, "AVWAP Dist", na(avwapDistPct) ? "N/A" : str.tostring(avwapDistPct, "#.#") + "%", color.white, valid_AVWAP ? color.green : color.gray, dashTheme, dSize)
        r += 1
    if showRow22
        f_cell(dashTable, dashOrient, r, "IWM/QQQ RS", not rsAppl ? "N/A" : valid_RS ? "LEAD" : "LAG", color.white, not rsAppl ? color.gray : valid_RS ? color.green : color.red, dashTheme, dSize)
        r += 1

//---------------------------------------------------------------------------------------------------------------------}
// 7. INSTITUTIONAL ALERTS (FIXED CONST STRING)
//---------------------------------------------------------------------------------------------------------------------{
// 1. Alert for Trend Alignment (When Header turns Aqua)
alertcondition(trendSync and not trendSync[1], title="LUK Trend Sync: AQUA", message="LUK Trend Sync: Aqua Header Active.")

// 2. High-Conviction "Luk" Entry
// Note: We use the global 'lukSignalSync' variable defined in Section 5
alertcondition(lukSignalSync, title="LUK High Conviction Entry", message="LUK BREAKOUT: Entry signal triggered with full breadth and trend alignment!")

// 3. Profit Target Alert (3.0R)
alertcondition(currentR >= 3.0 and currentR[1] < 3.0, title="LUK 3R Target Hit", message="LUK Target Hit: 3.0R reached.")

// 4. STOP LOSS HIT ALERT
bool stopHit = (isHTF ? monActive : activeTrade) and low <= reportSL
alertcondition(stopHit and not stopHit[1], title="LUK STOP LOSS HIT", message="LUK EXIT: Price has crossed the Vol Stop.")

// 5. DYNAMIC ORH / ORL BREAK ALERTS (session-aware: follows Selection Mode + Preset/Manual window)
// These use the alert() function so the message can embed the ACTIVE session window (session_time)
// and the exact price level. To enable in TradingView:
//   Create Alert -> Condition -> this indicator -> "Any alert() function call".
// NOTE: alert() function calls do NOT work in the Pine Screener. For the screener, use alert #6 below.
bool orhBreak = not na(orh) and close > orh and close[1] <= orh
bool orlBreak = not na(orl) and close < orl and close[1] >= orl
if orhBreak
    alert("ORH BREAKOUT: price closed above the " + session_time + " Opening Range High (" + str.tostring(orh, format.mintick) + ").", alert.freq_once_per_bar_close)
if orlBreak
    alert("ORL BREAKDOWN: price closed below the " + session_time + " Opening Range Low (" + str.tostring(orl, format.mintick) + ").", alert.freq_once_per_bar_close)

// 6. STATIC 5-MIN ORH BREAK -> "LUK ORH 5 MINS" (for Pine Screener)
// Fixed 0930-0935 opening range, INDEPENDENT of the Selection Mode / Preset inputs above,
// so it always screens the true 5-minute ORB regardless of how the indicator is configured.
// Uses alertcondition() with a constant message because the Pine Screener requires that (it cannot use alert()).
var float orh5 = na
var float orl5 = na
bool or5_sesh   = not na(time(timeframe.period, "0930-0935", tz))
bool or5_start  = or5_sesh and not or5_sesh[1]
if or5_start
    orh5 := high
    orl5 := low
if or5_sesh
    orh5 := math.max(orh5, high)
    orl5 := math.min(orl5, low)
bool orh5Break = not na(orh5) and close > orh5 and close[1] <= orh5
alertcondition(orh5Break, title="LUK ORH 5 MINS", message="LUK ORH 5 MINS: 5m candle closed above the 0930-0935 Opening Range High.")
